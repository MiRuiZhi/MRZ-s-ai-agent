
# ========== LLM 基础配置 ==========
OPENAI_API_KEY=<your openai api key>
# 与 Java `llm.default.base_url` 保持一致；Python 侧会自动拼接 `/v1/chat/completions`
OPENAI_BASE_URL=https://www.openclaudecode.cn

# 图片生成专用配置；默认复用通用 OpenAI 兼容网关，也可按需单独覆盖
IMAGE_GENERATION_BASE_URL=${OPENAI_BASE_URL}
IMAGE_GENERATION_API_KEY=${OPENAI_API_KEY}
IMAGE_GENERATION_MODEL=gpt-image-2

# DashScope API Key（MRAG 多模态能力共用：Embedding / VLM / Rerank）
DASHSCOPE_API_KEY=<your dashscope api key>
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 如果使用deepseek，请使用如下变量
# DEEPSEEK_API_KEY=<your deepseek api key>

# <a href="https://docs.litellm.ai/docs/providers">其他模型支持文档</a>
# ANTHROPIC_API_KEY=<or anthropic api key>
# ANTHROPIC_API_BASE=<your base url>

# 敏感词过滤
SENSITIVE_WORD_REPLACE=true

# 文件系统路径配置
FILE_SAVE_PATH=file_db_dir
SQLITE_DB_PATH=autobots.db
FILE_SERVER_URL=http://127.0.0.1:1601/v1/file_tool

# ========== DeepSearch 配置 ==========
# DeepSearch 专用大模型配置；留空时回退到 OPENAI_BASE_URL / OPENAI_API_KEY
DEEPSEARCH_BASE_URL=${OPENAI_BASE_URL}
DEEPSEARCH_API_KEY=${OPENAI_API_KEY}

USE_JD_SEARCH_GATEWAY=false
USE_SEARCH_ENGINE=ddg
DDG_REGION=wt-wt
DDG_SAFESEARCH=moderate
JINA_API_KEY=
JINA_READER_TIMEOUT=15
SEARCH_COUNT=10
SEARCH_TIMEOUT=100000
SEARCH_THREAD_NUM=5
DEEPSEARCH_TOTAL_TIMEOUT_SECONDS=1200

DEFAULT_MODEL=gpt-5.2

QUERY_DECOMPOSE_MODEL=${DEFAULT_MODEL}
QUERY_DECOMPOSE_THINK_MODEL=${DEFAULT_MODEL}
QUERY_DECOMPOSE_MAX_SIZE=2
SEARCH_REASONING_MODEL=${DEFAULT_MODEL}
SEARCH_ANSWER_MODEL=${DEFAULT_MODEL}
SEARCH_ANSWER_LENGTH=10000
REPORT_MODEL=gpt-5.4

SINGLE_PAGE_MAX_SIZE=6

# Exa Search
EXA_SEARCH_URL=https://api.exa.ai/search
EXA_API_KEY=

#  tavily API KEY=

BING_SEARCH_URL=
BING_SEARCH_API_KEY=

JINA_SEARCH_URL=https://s.jina.ai/
JINA_SEARCH_API_KEY=

SOGOU_SEARCH_URL=
SOGOU_SEARCH_API_KEY=

SERPER_SEARCH_URL=https://google.serper.dev/search
SERPER_SEARCH_API_KEY=

# Code Interpreter 配置
CODE_INTEPRETER_MODEL=gpt-5.4

# ========== table_rag 配置 ==========
TR_QDRANT_URL=
TR_QDRANT_COLLECTION_NAME=
TR_QDRANT_ENABLE=false
TR_QDRANT_HOST=
TR_QDRANT_PORT=6334
TR_QDRANT_API_KEY=
TR_QDRANT_PREFER_GRPC=true
TR_EMBEDDING_URL=

TR_BUSINESS_PROMPT_MAX_LENGTH=3000
TR_SCHEMA_LIST_MAX_LENGTH=200
TR_USE_PROMPT_MAX_LENGTH=500

TR_EXTRACT_SYS_WSD_MODEL_NAME=${DEFAULT_MODEL}
TR_TABLE_FILTER_MODEL_NAME=${DEFAULT_MODEL}
TR_COLUMN_FILTER_MODEL_NAME=${DEFAULT_MODEL}

TR_IS_FIRST_FILTER_TABLE=true
TR_NEED_FILTER_TABLE_MIN_LENGTH=3
TR_TABLE_FILTER_BATCH_SIZE=5

#TR_ES_CONFIGS_HOST=
#TR_ES_CONFIGS_USER=
#TR_ES_CONFIGS_PASSWORD=
#TR_ES_CONFIGS_SCHEME=http
#TR_ES_CONFIGS_INDEX=

TR_ES_CONFIGS_HOST=
TR_ES_CONFIGS_USER=
TR_ES_CONFIGS_PASSWORD=
TR_ES_CONFIGS_SCHEME=http
TR_ES_CONFIGS_INDEX=

# ES CONFIG
TR_ES_RECALL_TOP_K=15

TR_QD_THRESHHOLD=0.4
TR_QD_RECALL_TOP_K=30
TR_QD_TIMEOUT=999999
TR_USE_RERANK=false
TR_BGE_RERANK_URL=
TR_RERANK_TOPK=5

# ========== cal engine 配置 ==========
CAL_ENGINE_MODEL=${DEFAULT_MODEL}

# ========== Analysis ==========
ANA_SCHEMA_URL=http://localhost:8080/data/queryModelInfo
ANA_DATA_URL=http://localhost:8080/data/apiChatQuery
ANALYSIS_MODEL=gpt-5.4

# ========== NL2SQL ==========
NL2SQL_MODEL_NAME=gpt-5.4
REWRITE_MODEL_NAME=gpt-5.4
THINK_MODEL_NAME=gpt-5.4

# ================MRAG=============
# LLM model (MRAG 回答生成专用，不填则复用 OPENAI_API_KEY / OPENAI_BASE_URL)
LLM_API_KEY=${OPENAI_API_KEY}
LLM_MODEL_BASE_URL=${OPENAI_BASE_URL}
LLM_MODEL_NAME=gpt-5.2

# VLM model (图片理解)
VLM_TYPE=openai
VLM_MODEL_BASE_URL=${OPENAI_BASE_URL}
VLM_API_KEY=${OPENAI_API_KEY}
VLM_MODEL_NAME=gpt-5.2

# text embedding model (文本向量化)
TEXT_EMBEDDING_TYPE=openai
TEXT_EMBEDDING_BASE_URL=${DASHSCOPE_API_BASE}
TEXT_EMBEDDING_API_KEY=${DASHSCOPE_API_KEY}
TEXT_EMBEDDING_MODEL_NAME=text-embedding-v4
TEXT_EMBEDDING_MAX_TEXT_LENGTH=8000
TEXT_EMBEDDING_DIMENSION=1024

# multimodal embedding model (图片向量化)
IMAGE_EMBEDDING_TYPE=dashscope
DASHSCOPE_MULTIMODAL_EMBEDDING_BASE_URL=
DASHSCOPE_MULTIMODAL_EMBEDDING_MODEL_NAME=
IMAGE_EMBEDDING_DIMENSION=1024

# OCR model (文档解析: vlm-ocr 或 deepseek-ocr)
OCR_TYPE=vlm-ocr
DEEPSEEK_OCR_BASE_URL=
DEEPSEEK_OCR_API_KEY=
DEEPSEEK_OCR_MODEL_NAME=

# text reranker model (检索重排序)
ENABLE_RERANKER=true
TEXT_RERANKER_TYPE=api
TEXT_RERANKER_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
TEXT_RERANKER_API_KEY=${DASHSCOPE_API_KEY}
TEXT_RERANKER_MODEL_NAME=gte-rerank

# MinerU (PDF 文档解析服务)
MINERU_BASE_URL=https://mineru.net/api/v4/extract/task
MINERU_API_KEY=<your mineru api key>

# text split (文本切分策略)
CHUNK_TYPE=markdown
CHUNK_SIZE=500
CHUNK_OVERLAP=100
ENABLE_SUB_CHUNK_ENHANCE=true
SUB_CHUNK_SIZE=100

# retrieval thresholds (检索相似度阈值)
RETRIEVAL_TEXT_THRESHOLD=0.45
RETRIEVAL_IMAGE_THRESHOLD=0.6
RETRIEVAL_PAGE_THRESHOLD=0.35

# storage (向量存储)
VECTOR_STORE_TYPE=qdrant
QDRANT_URL=https://your-cluster-id.us-west-1-0.aws.cloud.qdrant.io:443
QDRANT_PORT=6334
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=true
QDRANT_TIMEOUT=30

# metadata storage (元数据存储)
STORE_TYPE=sqlite
SQLITE_PATH=/tmp/mrag_sqlite.db

# default knowledge base
DEFAULT_KB_ID=1

# Qdrant collection names
TEXT_COLLECTION=t_reactor_mrag_text_vectors
IMAGE_COLLECTION=t_reactor_mrag_image_vectors
PAGE_COLLECTION=t_reactor_mrag_page_vectors

# object storage (文档原始文件存储)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_DIR=mrag
OSS_SERVER_BASE_URL=http://127.0.0.1:8000/storage

API_TIMEOUT=300

# LightRAG (可选替代方案)
LIGHTRAG_SERVER_BASE_URL=
# ================MRAG END =============
