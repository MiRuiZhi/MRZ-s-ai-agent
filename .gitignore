*.o
*.obj
*.exe

# Frontend package manager policy: pnpm is canonical.
/ui/package-lock.json

# Runtime skills: keep source code, ignore generated state.
runtime/skills/*/__pycache__/
runtime/skills/*/*.pyc
runtime/skills/*/.venv/
runtime/skills/*/output/
runtime/skills/*/tools/vector_index.json

